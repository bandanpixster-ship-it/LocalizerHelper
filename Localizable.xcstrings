        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersetzen Sie Ihre Dokumente nahtlos und ohne Unterbrechungen, auch offline."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Translate your documents seamlessly, without interruptions, even offline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduce tus documentos sin problemas, sin interrupciones, incluso sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduisez vos documents en toute transparence, sans interruption, même hors ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने दस्तावेज़ों का अनुवाद निर्बाध रूप से, बिना किसी रुकावट के, ऑफ़लाइन भी करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prevodite svoje dokumente neprimjetno, bez prekida, čak i izvan mreže."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terjemahkan dokumen Anda dengan lancar, tanpa gangguan, bahkan secara offline."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुमचे दस्तऐवज अखंडपणे, कोणत्याही व्यत्ययाशिवाय, अगदी ऑफलाइन भाषांतरित करा."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduza seus documentos com facilidade, sem interrupções, mesmo off-line."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்கள் ஆவணங்களை தடையின்றி, ஆஃப்லைனிலும் மொழிபெயர்க்கலாம்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీ పత్రాలను అంతరాయాలు లేకుండా, ఆఫ్‌లైన్‌లో కూడా అనువదించండి."
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humusha amadokhumenti akho kalula, ngaphandle kweziphazamiso, ngisho ungaxhunyiwe ku-inthanethi."
          }
        }
      }
    },
    "Translate your documents with ease, even when you're offline. Always at your fingertips." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertaal jou dokumente met gemak, selfs wanneer jy vanlyn is. Altyd by jou vingers."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি অফলাইনে থাকাকালীনও আপনার নথিগুলি সহজে অনুবাদ করুন৷ সর্বদা আপনার নখদর্পণে."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersetzen Sie Ihre Dokumente ganz einfach, auch wenn Sie offline sind. Immer griffbereit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Translate your documents with ease, even when you're offline. Always at your fingertips."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduce tus documentos con facilidad, incluso cuando no estés conectado. Siempre a tu alcance."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduisez facilement vos documents, même lorsque vous êtes hors ligne. Toujours à portée de main."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऑफ़लाइन होने पर भी अपने दस्तावेज़ों का आसानी से अनुवाद करें। हमेशा आपकी उंगलियों पर."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prevedite svoje dokumente s lakoćom, čak i kada ste izvan mreže. Uvijek na dohvat ruke."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terjemahkan dokumen Anda dengan mudah, bahkan saat Anda sedang offline. Selalu di ujung jari Anda."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुम्ही ऑफलाइन असतानाही तुमचे दस्तऐवज सहजतेने भाषांतरित करा. नेहमी आपल्या बोटांच्या टोकावर."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduza seus documentos com facilidade, mesmo quando estiver offline. Sempre ao seu alcance."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "நீங்கள் ஆஃப்லைனில் இருந்தாலும், உங்கள் ஆவணங்களை எளிதாக மொழிபெயர்க்கலாம். எப்போதும் உங்கள் விரல் நுனியில்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీరు ఆఫ్‌లైన్‌లో ఉన్నప్పుడు కూడా మీ పత్రాలను సులభంగా అనువదించండి. ఎల్లప్పుడూ మీ చేతివేళ్ల వద్ద."
