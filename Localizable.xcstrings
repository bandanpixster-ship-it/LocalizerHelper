            "value" : "Para usar a câmera, ative o acesso nas configurações do seu dispositivo."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "கேமராவைப் பயன்படுத்த, உங்கள் சாதன அமைப்புகளில் அணுகலை இயக்கவும்."
          }
        },
        "te" : {
          "stringUnit" : {
