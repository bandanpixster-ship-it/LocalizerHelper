    "Upgrade to Premium for an enhanced experience with unlimited access to advanced features and complete benefits" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gradeer op na Premium vir 'n verbeterde ervaring met onbeperkte toegang tot gevorderde kenmerke en volledige voordele"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "উন্নত বৈশিষ্ট্য এবং সম্পূর্ণ সুবিধাগুলিতে সীমাহীন অ্যাক্সেস সহ একটি বর্ধিত অভিজ্ঞতার জন্য প্রিমিয়ামে আপগ্রেড করুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upgraden Sie auf Premium für ein erweitertes Erlebnis mit unbegrenztem Zugriff auf erweiterte Funktionen und umfassende Vorteile"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upgrade to Premium for an enhanced experience with unlimited access to advanced features and complete benefits"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualice a Premium para disfrutar de una experiencia mejorada con acceso ilimitado a funciones avanzadas y beneficios completos"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passez à Premium pour une expérience améliorée avec un accès illimité aux fonctionnalités avancées et aux avantages complets"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उन्नत सुविधाओं और संपूर्ण लाभों तक असीमित पहुंच के साथ बेहतर अनुभव के लिए प्रीमियम में अपग्रेड करें"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadogradite na Premium za poboljšano iskustvo s neograničenim pristupom naprednim značajkama i svim pogodnostima"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tingkatkan ke Premium untuk pengalaman yang lebih baik dengan akses tak terbatas ke fitur-fitur canggih dan manfaat lengkap"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रगत वैशिष्ट्यांमध्ये अमर्याद प्रवेशासह वर्धित अनुभवासाठी प्रीमियम वर श्रेणीसुधारित करा आणि संपूर्ण लाभ"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atualize para Premium para uma experiência aprimorada com acesso ilimitado a recursos avançados e benefícios completos"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "மேம்பட்ட அம்சங்கள் மற்றும் முழுமையான பலன்களுக்கான வரம்பற்ற அணுகலுடன் மேம்பட்ட அனுபவத்தைப் பெற Premium க்கு மேம்படுத்தவும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "అధునాతన ఫీచర్‌లు మరియు పూర్తి ప్రయోజనాలకు అపరిమిత యాక్సెస్‌తో మెరుగైన అనుభవం కోసం Premiumకి అప్‌గ్రేడ్ చేయండి"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thuthukela ku-Premium ukuze uthole okuhlangenwe nakho okuthuthukisiwe nokufinyelela okungenamkhawulo kuzici ezithuthukile nezinzuzo eziphelele"
          }
        }
      }
    },
