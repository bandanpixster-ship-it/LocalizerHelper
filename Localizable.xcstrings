    "To use speech features, please enable speech recognition in your device settings" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiveer asseblief spraakherkenning in jou toestelinstellings om spraakkenmerke te gebruik"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "বক্তৃতা বৈশিষ্ট্যগুলি ব্যবহার করতে, অনুগ্রহ করে আপনার ডিভাইস সেটিংসে বক্তৃতা শনাক্তকরণ সক্ষম করুন৷"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um Sprachfunktionen nutzen zu können, aktivieren Sie bitte die Spracherkennung in Ihren Geräteeinstellungen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use speech features, please enable speech recognition in your device settings"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para utilizar las funciones de voz, habilite el reconocimiento de voz en la configuración de su dispositivo"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour utiliser les fonctionnalités vocales, veuillez activer la reconnaissance vocale dans les paramètres de votre appareil."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वाक् सुविधाओं का उपयोग करने के लिए, कृपया अपनी डिवाइस सेटिंग में वाक् पहचान सक्षम करें"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Za korištenje govornih značajki omogućite prepoznavanje govora u postavkama uređaja"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untuk menggunakan fitur ucapan, aktifkan pengenalan ucapan di pengaturan perangkat Anda"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उच्चार वैशिष्ट्ये वापरण्यासाठी, कृपया तुमच्या डिव्हाइस सेटिंग्जमध्ये उच्चार ओळख सक्षम करा"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar recursos de fala, ative o reconhecimento de fala nas configurações do seu dispositivo"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "பேச்சு அம்சங்களைப் பயன்படுத்த, உங்கள் சாதன அமைப்புகளில் பேச்சு அங்கீகாரத்தை இயக்கவும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ప్రసంగ లక్షణాలను ఉపయోగించడానికి, దయచేసి మీ పరికర సెట్టింగ్‌లలో ప్రసంగ గుర్తింపును ప్రారంభించండి"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukuze usebenzise izici zenkulumo, sicela unike amandla ukubonwa kwenkulumo kuzilungiselelo zedivayisi yakho"
          }
        }
      }
    },
    "To use the camera, please enable access in your device settings." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
