    "Are you sure you want to delete this bookmark? Your history will remain unaffected" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is jy seker jy wil hierdie boekmerk uitvee? Jou geskiedenis sal onaangeraak bly"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি কি এই বুকমার্ক মুছে ফেলার বিষয়ে নিশ্চিত? আপনার ইতিহাস প্রভাবিত হবে না"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie dieses Lesezeichen wirklich löschen? Ihre Historie bleibt davon unberührt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete this bookmark? Your history will remain unaffected"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea eliminar este marcador? Tu historial no se verá afectado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etes-vous sûr de vouloir supprimer ce favori ? Votre historique ne sera pas affecté"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई इस बुकमार्क को हटाना चाहते हैं? आपका इतिहास अप्रभावित रहेगा"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeste li sigurni da želite izbrisati ovu oznaku? Vaša će povijest ostati nepromijenjena"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apakah Anda yakin ingin menghapus bookmark ini? Riwayat Anda tidak akan terpengaruh"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुमची खात्री आहे की तुम्ही हा बुकमार्क हटवू इच्छिता? तुमचा इतिहास अप्रभावित राहील"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja excluir este favorito? Seu histórico permanecerá inalterado"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "இந்தப் புக்மார்க்கை நிச்சயமாக நீக்க விரும்புகிறீர்களா? உங்கள் வரலாறு பாதிக்கப்படாமல் இருக்கும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీరు ఖచ్చితంగా ఈ బుక్‌మార్క్‌ని తొలగించాలనుకుంటున్నారా? మీ చరిత్ర ప్రభావితం కాకుండా ఉంటుంది"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uqinisekile ukuthi ufuna ukususa le bhukhimakhi? Umlando wakho uzohlala ungathinteki"
          }
        }
      }
    },
