    "Your bookmarks will be erased, but your history stays. Do you want to continue?" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jou boekmerke sal uitgevee word, maar jou geskiedenis bly. Wil jy voortgaan?"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার বুকমার্ক মুছে ফেলা হবে, কিন্তু আপনার ইতিহাস থেকে যায়. আপনি কি চালিয়ে যেতে চান?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Lesezeichen werden gelöscht, Ihr Verlauf bleibt jedoch erhalten. Möchten Sie fortfahren?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your bookmarks will be erased, but your history stays. Do you want to continue?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus marcadores se borrarán, pero tu historial permanecerá. ¿Quieres continuar?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos favoris seront effacés, mais votre historique restera. Voulez-vous continuer ?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके बुकमार्क मिटा दिए जाएंगे, लेकिन आपका इतिहास बना रहेगा। क्या आप जारी रखना चाहते हैं?"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaše će oznake biti izbrisane, ali vaša povijest ostaje. Želite li nastaviti?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bookmark Anda akan dihapus, tetapi riwayat Anda tetap ada. Apakah Anda ingin melanjutkan?"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुमचे बुकमार्क मिटवले जातील, पण तुमचा इतिहास तसाच राहील. तुम्हाला सुरू ठेवायचे आहे का?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus favoritos serão apagados, mas seu histórico permanecerá. Você quer continuar?"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்கள் புக்மார்க்குகள் அழிக்கப்படும், ஆனால் உங்கள் வரலாறு அப்படியே இருக்கும். தொடர வேண்டுமா?"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీ బుక్‌మార్క్‌లు తొలగించబడతాయి, కానీ మీ చరిత్ర అలాగే ఉంటుంది. మీరు కొనసాగించాలనుకుంటున్నారా?"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amabhukumaka akho azosulwa, kodwa umlando wakho uhlezi. Uyafuna ukuqhubeka?"
          }
        }
      }
    },
