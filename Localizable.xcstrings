    "Translate text into over 200 languages, anytime you need it, no matter where you are — even offline." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertaal teks in meer as 200 tale, enige tyd wat jy dit nodig het, maak nie saak waar jy is nie – selfs vanlyn."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "200 টিরও বেশি ভাষায় পাঠ্য অনুবাদ করুন, যেকোনো সময় আপনার প্রয়োজন, আপনি যেখানেই থাকুন না কেন - এমনকি অফলাইনেও৷"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersetzen Sie Text in über 200 Sprachen, wann immer Sie ihn brauchen, egal wo Sie sind – sogar offline."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Translate text into over 200 languages, anytime you need it, no matter where you are — even offline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduce texto a más de 200 idiomas, en cualquier momento que lo necesites, sin importar dónde estés, incluso sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduisez du texte dans plus de 200 langues, à tout moment, où que vous soyez, même hors ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टेक्स्ट का 200 से अधिक भाषाओं में अनुवाद करें, जब भी आपको इसकी आवश्यकता हो, चाहे आप कहीं भी हों - ऑफ़लाइन भी।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prevedite tekst na više od 200 jezika, kad god vam zatreba, bez obzira gdje se nalazite — čak i izvan mreže."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terjemahkan teks ke lebih dari 200 bahasa, kapan pun Anda membutuhkannya, di mana pun Anda berada — bahkan saat offline."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "200 हून अधिक भाषांमध्ये मजकूराचे भाषांतर करा, तुम्हाला त्याची आवश्यकता असताना, तुम्ही कुठेही असाल - अगदी ऑफलाइन देखील."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduza textos para mais de 200 idiomas, sempre que precisar, não importa onde você esteja, mesmo off-line."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "200 க்கும் மேற்பட்ட மொழிகளில் உரையை மொழிபெயர்க்கலாம், எந்த நேரத்திலும், நீங்கள் எங்கிருந்தாலும் - ஆஃப்லைனில் கூட."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "టెక్స్ట్‌ని 200కి పైగా భాషల్లోకి అనువదించండి, మీకు అవసరమైనప్పుడు, మీరు ఎక్కడ ఉన్నా — ఆఫ్‌లైన్‌లో కూడా."
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humushela umbhalo ezilimini ezingaphezu kuka-200, noma nini uma uwudinga, kungakhathaliseki ukuthi ukuphi — ngisho noma ungaxhunyiwe ku-inthanethi."
          }
