    "Scan text in real-time with your camera and get instant translations, wherever you are." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skandeer teks intyds met jou kamera en kry onmiddellike vertalings, waar jy ook al is."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার ক্যামেরা দিয়ে রিয়েল-টাইমে পাঠ্য স্ক্যান করুন এবং আপনি যেখানেই থাকুন না কেন তাৎক্ষণিক অনুবাদ পান।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scannen Sie Text in Echtzeit mit Ihrer Kamera und erhalten Sie sofortige Übersetzungen, wo immer Sie sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan text in real-time with your camera and get instant translations, wherever you are."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escanee texto en tiempo real con su cámara y obtenga traducciones instantáneas, esté donde esté."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Numérisez du texte en temps réel avec votre appareil photo et obtenez des traductions instantanées, où que vous soyez."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने कैमरे से वास्तविक समय में टेक्स्ट को स्कैन करें और आप जहां भी हों, तत्काल अनुवाद प्राप्त करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skenirajte tekst u stvarnom vremenu svojom kamerom i dobijte trenutne prijevode, gdje god se nalazili."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pindai teks secara real-time dengan kamera Anda dan dapatkan terjemahan instan, di mana pun Anda berada."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुमच्या कॅमेऱ्याने रीअल टाइममध्ये मजकूर स्कॅन करा आणि तुम्ही कुठेही असल्यावर झटपट भाषांतर मिळवा."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Digitalize texto em tempo real com sua câmera e obtenha traduções instantâneas, onde quer que você esteja."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்கள் கேமரா மூலம் நிகழ்நேரத்தில் உரையை ஸ்கேன் செய்து, நீங்கள் எங்கிருந்தாலும் உடனடி மொழிபெயர்ப்புகளைப் பெறுங்கள்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీ కెమెరాతో నిజ సమయంలో వచనాన్ని స్కాన్ చేయండి మరియు మీరు ఎక్కడ ఉన్నా తక్షణ అనువాదాలను పొందండి."
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skena umbhalo ngesikhathi sangempela ngekhamera yakho futhi uthole ukuhumusha okusheshayo, noma ngabe ukuphi."
          }
        }
      }
    },
