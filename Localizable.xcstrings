    "Your device doesn't support Live Text scanning. Ensure you have a compatible device and camera access enabled" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jou toestel ondersteun nie regstreekse teksskandering nie. Maak seker dat jy 'n versoenbare toestel en kameratoegang geaktiveer het"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার ডিভাইস লাইভ টেক্সট স্ক্যানিং সমর্থন করে না। আপনার একটি সামঞ্জস্যপূর্ণ ডিভাইস এবং ক্যামেরা অ্যাক্সেস সক্ষম আছে তা নিশ্চিত করুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Gerät unterstützt das Scannen von Live-Text nicht. Stellen Sie sicher, dass Sie über ein kompatibles Gerät und einen aktivierten Kamerazugriff verfügen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your device doesn't support Live Text scanning. Ensure you have a compatible device and camera access enabled"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su dispositivo no admite el escaneo de Live Text. Asegúrese de tener un dispositivo compatible y acceso a la cámara habilitado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre appareil ne prend pas en charge la numérisation Live Text. Assurez-vous que vous disposez d'un appareil compatible et que l'accès à la caméra est activé"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका डिवाइस लाइव टेक्स्ट स्कैनिंग का समर्थन नहीं करता है. सुनिश्चित करें कि आपके पास एक संगत डिवाइस और कैमरा एक्सेस सक्षम है"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaš uređaj ne podržava skeniranje teksta uživo. Provjerite imate li omogućen pristup kompatibilnom uređaju i kameri"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perangkat Anda tidak mendukung pemindaian Teks Langsung. Pastikan Anda mengaktifkan perangkat yang kompatibel dan akses kamera"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुमचे डिव्हाइस थेट मजकूर स्कॅनिंगला सपोर्ट करत नाही. तुमच्याकडे सुसंगत डिव्हाइस आणि कॅमेरा प्रवेश सक्षम असल्याची खात्री करा"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu dispositivo não oferece suporte à digitalização de texto ativo. Certifique-se de ter um dispositivo compatível e o acesso à câmera ativado"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்கள் சாதனம் லைவ் டெக்ஸ்ட் ஸ்கேனிங்கை ஆதரிக்கவில்லை. உங்களிடம் இணக்கமான சாதனம் மற்றும் கேமரா அணுகல் இயக்கப்பட்டிருப்பதை உறுதிசெய்யவும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీ పరికరం లైవ్ టెక్స్ట్ స్కానింగ్‌కు మద్దతు ఇవ్వదు. మీకు అనుకూల పరికరం మరియు కెమెరా యాక్సెస్ ప్రారంభించబడిందని నిర్ధారించుకోండి"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Idivayisi yakho ayikusekeli ukuskena kombhalo obukhoma. Qinisekisa ukuthi unedivayisi ehambisanayo nokufinyelela kwekhamera okunikwe amandla"
          }
        }
      }
    },
