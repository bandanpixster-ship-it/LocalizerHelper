    "Break down language barriers in real-time conversations. Stay connected, even offline." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breek taalhindernisse af in intydse gesprekke. Bly verbind, selfs vanlyn."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "রিয়েল-টাইম কথোপকথনে ভাষার বাধাগুলি ভেঙে দিন। সংযুক্ত থাকুন, এমনকি অফলাইনেও।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überwinden Sie Sprachbarrieren in Echtzeitgesprächen. Bleiben Sie in Verbindung, auch offline."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Break down language barriers in real-time conversations. Stay connected, even offline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rompe las barreras del idioma en conversaciones en tiempo real. Manténgase conectado, incluso sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éliminez les barrières linguistiques dans les conversations en temps réel. Restez connecté, même hors ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वास्तविक समय की बातचीत में भाषा संबंधी बाधाओं को तोड़ें। ऑफ़लाइन रहते हुए भी जुड़े रहें."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Srušite jezične barijere u razgovorima u stvarnom vremenu. Ostanite povezani, čak i izvan mreže."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilangkan hambatan bahasa dalam percakapan waktu nyata. Tetap terhubung, bahkan saat offline."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "रिअल-टाइम संभाषणांमध्ये भाषेतील अडथळे दूर करा. कनेक्टेड रहा, अगदी ऑफलाइन देखील."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quebre as barreiras linguísticas em conversas em tempo real. Fique conectado, mesmo offline."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "நிகழ்நேர உரையாடல்களில் மொழி தடைகளை உடைக்கவும். ஆஃப்லைனில் இருந்தாலும் இணைந்திருங்கள்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "నిజ-సమయ సంభాషణలలో భాషా అడ్డంకులను విచ్ఛిన్నం చేయండి. ఆఫ్‌లైన్‌లో కూడా కనెక్ట్ అయి ఉండండి."
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hlukanisa izithiyo zolimi ezingxoxweni zesikhathi sangempela. Hlala uxhumekile, ngisho ungaxhunyiwe ku-inthanethi."
          }
        }
      }
    },
