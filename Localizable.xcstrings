    "Speak into the mic, and your words will\\nbe translated into the preferred language" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praat in die mikrofoon, en jou woorde sal\\n in die voorkeurtaal vertaal word"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মাইকে কথা বলুন, এবং আপনার শব্দগুলি পছন্দের ভাষায় অনুবাদ করা হবে"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sprechen Sie in das Mikrofon und Ihre Worte werden in die bevorzugte Sprache übersetzt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speak into the mic, and your words will\\nbe translated into the preferred language"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habla por el micrófono y tus palabras\\nse traducirán al idioma preferido"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parlez dans le micro et vos mots seront\\ntraduits dans la langue de votre choix."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइक में बोलें, और आपके शब्दों का पसंदीदा भाषा में अनुवाद किया जाएगा"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Govorite u mikrofon i vaše će riječi\\nbiti prevedene na željeni jezik"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bicaralah ke mikrofon, dan kata-kata Anda akan\\nditerjemahkan ke dalam bahasa pilihan"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माइकवर बोला आणि तुमचे शब्द प्राधान्यकृत भाषेत भाषांतरित केले जातील"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fale no microfone e suas palavras serão\\ntraduzidas para o idioma de sua preferência"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "மைக்கில் பேசுங்கள், உங்கள் வார்த்தைகள்\\nவிருப்பமான மொழியில் மொழிபெயர்க்கப்படும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మైక్‌లో మాట్లాడండి, మీ పదాలు\\nప్రాధాన్య భాషలోకి అనువదించబడతాయి"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khuluma kumakrofoni, futhi amagama akho\\nizohunyushelwa olimini oluncanyelwayo"
          }
        }
      }
    },
