        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்களின் இறுதிப் பயணம் இன்றியமையாதது - நிகழ்நேர மொழிபெயர்ப்பு, எங்கும் - AI ஐ மொழிபெயர்க்கவும்"
