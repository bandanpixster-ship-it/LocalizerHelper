    "We couldn't detect any text in the image. Please make sure the text is clear and visible, then try again." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ons kon geen teks in die prent bespeur nie. Maak asseblief seker dat die teks duidelik en sigbaar is, en probeer dan weer."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
