    "Caveat: SwiftUI Text() still uses the system language. Use .dynamicLocalized or LanguageManager explicitly." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waarskuwing: SwiftUI Text() gebruik steeds die stelseltaal. Gebruik .dynamicLocalized of LanguageManager eksplisiet."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সতর্কতা: SwiftUI Text() এখনও সিস্টেম ভাষা ব্যবহার করে। সুস্পষ্টভাবে .dynamicLocalized বা LanguageManager ব্যবহার করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vorsichtsmaßnahme: SwiftUI Text() verwendet weiterhin die Systemsprache. Verwenden Sie explizit .dynamicLocalized oder LanguageManager."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Advertencia: SwiftUI Text() todavía usa el idioma del sistema. Utilice .dynamicLocalized o LanguageManager explícitamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attention : SwiftUI Text() utilise toujours le langage système. Utilisez explicitement .dynamicLocalized ou LanguageManager."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चेतावनी: स्विफ्टयूआई टेक्स्ट() अभी भी सिस्टम भाषा का उपयोग करता है। स्पष्ट रूप से .dynamicLocalized या लेंग्वेजमैनेजर का उपयोग करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upozorenje: SwiftUI Text() još uvijek koristi jezik sustava. Izričito koristite .dynamicLocalized ili LanguageManager."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peringatan: SwiftUI Text() masih menggunakan bahasa sistem. Gunakan .dynamicLocalized atau LanguageManager secara eksplisit."
