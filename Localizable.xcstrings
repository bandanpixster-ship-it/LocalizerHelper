    "View translations on real-world objects in real-time with augmented reality. Available offline." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bekyk vertalings op werklike voorwerpe intyds met verhoogde werklikheid. Vanlyn beskikbaar."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "বর্ধিত বাস্তবতার সাথে রিয়েল-টাইমে বাস্তব-বিশ্বের বস্তুর অনুবাদগুলি দেখুন। অফলাইনে উপলব্ধ।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sehen Sie sich Übersetzungen von realen Objekten in Echtzeit mit Augmented Reality an. Offline verfügbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "View translations on real-world objects in real-time with augmented reality. Available offline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vea traducciones de objetos del mundo real en tiempo real con realidad aumentada. Disponible sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visualisez les traductions sur des objets du monde réel en temps réel grâce à la réalité augmentée. Disponible hors ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "संवर्धित वास्तविकता के साथ वास्तविक समय में वास्तविक दुनिया की वस्तुओं पर अनुवाद देखें। ऑफ़लाइन उपलब्ध है."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pregledajte prijevode na objektima stvarnog svijeta u stvarnom vremenu s proširenom stvarnošću. Dostupno izvan mreže."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lihat terjemahan objek dunia nyata secara real-time dengan augmented reality. Tersedia offline."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "संवर्धित वास्तविकतेसह रिअल-टाइममध्ये वास्तविक-जगातील वस्तूंवरील भाषांतरे पहा. ऑफलाइन उपलब्ध."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veja traduções de objetos do mundo real em tempo real com realidade aumentada. Disponível off-line."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ஆக்மென்ட் ரியாலிட்டியுடன் நிகழ்நேரத்தில் நிஜ உலகப் பொருள்களின் மொழிபெயர்ப்புகளைப் பார்க்கவும். ஆஃப்லைனில் கிடைக்கும்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ఆగ్మెంటెడ్ రియాలిటీతో నిజ-సమయంలో వాస్తవ-ప్రపంచ వస్తువులపై అనువాదాలను వీక్షించండి. ఆఫ్‌లైన్‌లో అందుబాటులో ఉంది."
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka ukuhumusha kwezinto zomhlaba wangempela ngesikhathi sangempela nge-augmented reality. Itholakala ungaxhunyiwe ku-inthanethi."
          }
        }
      }
    },
