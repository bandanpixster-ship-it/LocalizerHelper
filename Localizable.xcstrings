        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चेतावणी: SwiftUI Text() अजूनही सिस्टम भाषा वापरते. .dynamicLocalized किंवा LanguageManager स्पष्टपणे वापरा."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Advertência: SwiftUI Text() ainda usa a linguagem do sistema. Use .dynamicLocalized ou LanguageManager explicitamente."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "எச்சரிக்கை: SwiftUI Text() இன்னும் கணினி மொழியைப் பயன்படுத்துகிறது. .dynamicLocalized அல்லது LanguageManager ஐ வெளிப்படையாகப் பயன்படுத்தவும்."
