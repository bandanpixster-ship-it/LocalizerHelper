        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এআই-চালিত নির্ভুলতার সাথে পাঠ্য স্ক্যান করা এবং অনুবাদ করা শুরু করতে এখানে আলতো চাপুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie hier, um mit dem Scannen und\\nÜbersetzen von Text mit KI-gestützter Genauigkeit zu beginnen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap here to begin scanning and\\ntranslating text with AI-powered accuracy"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca aquí para comenzar a escanear y\\ntraducir texto con precisión impulsada por IA"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez ici pour commencer à numériser et\\ntraduire du texte avec une précision optimisée par l'IA"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एआई-संचालित सटीकता के साथ टेक्स्ट को स्कैन और अनुवाद करना शुरू करने के लिए यहां टैप करें"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodirnite ovdje za početak skeniranja i\\nprevođenja teksta s preciznošću koju pokreće AI"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ketuk di sini untuk mulai memindai dan\\nmenerjemahkan teks dengan akurasi yang didukung AI"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI-शक्तीच्या अचूकतेसह मजकूर स्कॅन करणे आणि अनुवादित करणे सुरू करण्यासाठी येथे टॅप करा"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque aqui para começar a digitalizar e\\ntraduzir texto com precisão baseada em IA"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI-இயங்கும் துல்லியத்துடன் உரையை ஸ்கேன் செய்து மொழியாக்கம் செய்ய இங்கே தட்டவும்"
