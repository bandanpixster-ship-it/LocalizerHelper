    "Tap here to begin scanning and\\ntranslating text with AI-powered accuracy" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik hier om teks met KI-aangedrewe akkuraatheid te begin skandeer en\\nvertaal"
