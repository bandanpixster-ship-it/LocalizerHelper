    "Long press on the text in the camera view\\nto get an accurate translation" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Druk lank op die teks in die kamera-aansig\\nom 'n akkurate vertaling te kry"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নির্ভুল অনুবাদ পেতে\\nক্যামেরা ভিউতে লেখাটির উপর দীর্ঘক্ষণ টিপুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drücken Sie lange auf den Text in der Kameraansicht,\\num eine genaue Übersetzung zu erhalten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long press on the text in the camera view\\nto get an accurate translation"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenga presionado el texto en la vista de la cámara\\npara obtener una traducción precisa"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez longuement sur le texte dans la vue caméra\\pour obtenir une traduction précise"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सटीक अनुवाद प्राप्त करने के लिए\\nकैमरा दृश्य में टेक्स्ट को देर तक दबाएँ"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dugo pritisnite tekst u prikazu kamere\\nza točan prijevod"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekan lama teks di tampilan kamera\\nuntuk mendapatkan terjemahan yang akurat"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अचूक भाषांतर मिळवण्यासाठी कॅमेरा व्ह्यूमध्ये मजकूरावर जास्त वेळ दाबून ठेवा"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha pressionado o texto na visualização da câmera\\para obter uma tradução precisa"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "துல்லியமான மொழிபெயர்ப்பைப் பெற, கேமரா காட்சியில்\\nஉரையை நீண்ட நேரம் அழுத்தவும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ఖచ్చితమైన అనువాదాన్ని పొందడానికి\\nకెమెరా వీక్షణలోని వచనంపై ఎక్కువసేపు నొక్కండి"
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cindezela isikhathi eside umbhalo ekubukeni kwekhamera\\ukuze uthole ukuhumusha okunembile"
          }
        }
      }
    },
