    "Please enable microphone access in your device settings to use voice features" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiveer asseblief mikrofoontoegang in jou toestelinstellings om stemkenmerke te gebruik"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ভয়েস বৈশিষ্ট্যগুলি ব্যবহার করতে অনুগ্রহ করে আপনার ডিভাইস সেটিংসে মাইক্রোফোন অ্যাক্সেস সক্ষম করুন৷"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte aktivieren Sie den Mikrofonzugriff in Ihren Geräteeinstellungen, um Sprachfunktionen zu nutzen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please enable microphone access in your device settings to use voice features"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilite el acceso al micrófono en la configuración de su dispositivo para usar las funciones de voz"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez activer l'accès au microphone dans les paramètres de votre appareil pour utiliser les fonctionnalités vocales."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ध्वनि सुविधाओं का उपयोग करने के लिए कृपया अपनी डिवाइस सेटिंग में माइक्रोफ़ोन एक्सेस सक्षम करें"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omogućite pristup mikrofonu u postavkama uređaja za korištenje glasovnih značajki"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harap aktifkan akses mikrofon di pengaturan perangkat Anda untuk menggunakan fitur suara"
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कृपया व्हॉइस वैशिष्ट्ये वापरण्यासाठी तुमच्या डिव्हाइस सेटिंग्जमध्ये मायक्रोफोन प्रवेश सक्षम करा"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ative o acesso ao microfone nas configurações do seu dispositivo para usar os recursos de voz"
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "குரல் அம்சங்களைப் பயன்படுத்த, உங்கள் சாதன அமைப்புகளில் மைக்ரோஃபோன் அணுகலை இயக்கவும்"
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "వాయిస్ ఫీచర్‌లను ఉపయోగించడానికి దయచేసి మీ పరికర సెట్టింగ్‌లలో మైక్రోఫోన్ యాక్సెస్‌ని ప్రారంభించండి"
          }
        },
        "zu" : {
          "stringUnit" : {
