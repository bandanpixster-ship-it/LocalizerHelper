    "Snap a photo and instantly translate text from images, such as menus and signs. Available offline." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maak 'n foto en vertaal teks onmiddellik vanaf beelde, soos spyskaarte en tekens. Vanlyn beskikbaar."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি ছবি তুলুন এবং তাৎক্ষণিকভাবে ছবি থেকে পাঠ্য অনুবাদ করুন, যেমন মেনু এবং চিহ্ন। অফলাইনে উপলব্ধ।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Machen Sie ein Foto und übersetzen Sie sofort Text aus Bildern, z. B. Menüs und Schildern. Offline verfügbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snap a photo and instantly translate text from images, such as menus and signs. Available offline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tome una foto y traduzca instantáneamente texto de imágenes, como menús y letreros. Disponible sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prenez une photo et traduisez instantanément le texte des images, comme les menus et les panneaux. Disponible hors ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक फोटो खींचें और मेनू और संकेतों जैसी छवियों से टेक्स्ट का तुरंत अनुवाद करें। ऑफ़लाइन उपलब्ध है."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snimite fotografiju i odmah prevedite tekst sa slika, poput izbornika i znakova. Dostupno izvan mreže."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ambil foto dan langsung terjemahkan teks dari gambar, seperti menu dan tanda. Tersedia offline."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "फोटो घ्या आणि मेनू आणि चिन्हे यांसारख्या प्रतिमांमधील मजकूर त्वरित अनुवादित करा. ऑफलाइन उपलब्ध."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tire uma foto e traduza instantaneamente texto de imagens, como menus e placas. Disponível off-line."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ஒரு புகைப்படத்தை எடுத்து, மெனுக்கள் மற்றும் அடையாளங்கள் போன்ற படங்களிலிருந்து உரையை உடனடியாக மொழிபெயர்க்கவும். ஆஃப்லைனில் கிடைக்கும்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ఫోటోను తీయండి మరియు మెనూలు మరియు సంకేతాల వంటి చిత్రాల నుండి వచనాన్ని తక్షణమే అనువదించండి. ఆఫ్‌లైన్‌లో అందుబాటులో ఉంది."
          }
        },
        "zu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thwebula isithombe bese uhumusha ngokushesha umbhalo osuka ezithombeni, njengamamenyu nezimpawu. Itholakala ungaxhunyiwe ku-inthanethi."
          }
        }
      }
    },
