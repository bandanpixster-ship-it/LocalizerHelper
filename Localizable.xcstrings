    "Works with .xcstrings — Xcode compiles it into en.lproj/Localizable.strings, fr.lproj/… at build time, so the bundle lookup succeeds." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Werk met .xcstrings — Xcode stel dit saam in en.lproj/Localizable.strings, fr.lproj/... tydens boutyd, sodat die bondelsoektog slaag."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".xcstrings-এর সাথে কাজ করে — Xcode এটিকে en.lproj/Localizable.strings, fr.lproj/… বিল্ড টাইমে কম্পাইল করে, তাই বান্ডেল লুকআপ সফল হয়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Funktioniert mit .xcstrings – Xcode kompiliert es zur Erstellungszeit in en.lproj/Localizable.strings, fr.lproj/…, sodass die Bundle-Suche erfolgreich ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Funciona con .xcstrings: Xcode lo compila en en.lproj/Localizable.strings, fr.lproj/… en el momento de la compilación, para que la búsqueda del paquete se realice correctamente."
          }
        },
